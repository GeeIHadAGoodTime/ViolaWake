# ViolaWake Console Backend - Environment Configuration
# Copy to .env and fill in values.

# Environment
# "development" (default) or "production"
VIOLAWAKE_ENV=development

# Server
# Port for uvicorn (default: 8000)
VIOLAWAKE_PORT=8000

# Security
# CRITICAL: Generate a unique secret key before deploying!
# Run: python -c "import secrets; print(secrets.token_urlsafe(64))"
# DO NOT use an empty key or 'changeme' in production!
# Minimum 32 characters required. In development, a random key is auto-generated on each startup.
VIOLAWAKE_SECRET_KEY=

# JWT algorithm (default: HS256)
VIOLAWAKE_ALGORITHM=HS256

# JWT token lifetime in hours (default: 24)
VIOLAWAKE_ACCESS_TOKEN_EXPIRE_HOURS=24

# CORS
# Comma-separated list of allowed origins.
# Default: http://localhost:5173,http://127.0.0.1:5173
# In production, https://console.violawake.com and https://violawake.com are
# appended automatically.
VIOLAWAKE_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Database
# Optional full SQLAlchemy async database URL.
# Set this on Railway to connect to PostgreSQL, for example:
# VIOLAWAKE_DB_URL=postgresql+asyncpg://user:password@host:5432/violawake
# If unset, the backend uses SQLite at VIOLAWAKE_DB_PATH.
VIOLAWAKE_DB_URL=

# Data paths
# Override these if you want filesystem-backed data somewhere else.
VIOLAWAKE_DATA_DIR=./data
VIOLAWAKE_DB_PATH=./data/violawake.db
VIOLAWAKE_UPLOAD_DIR=./data/recordings
VIOLAWAKE_MODELS_DIR=./data/models

# Cloudflare R2 object storage
# Leave unset in development to use the local filesystem backend.
VIOLAWAKE_R2_ENDPOINT=
VIOLAWAKE_R2_ACCESS_KEY_ID=
VIOLAWAKE_R2_SECRET_ACCESS_KEY=
VIOLAWAKE_R2_BUCKET=violawake

# Training
# Max training job duration in seconds before the watchdog kills it (default: 1800 = 30 min)
VIOLAWAKE_TRAINING_TIMEOUT=1800

# Max concurrent training jobs (default: 2)
VIOLAWAKE_MAX_CONCURRENT_JOBS=2

# Stripe billing (required when billing/checkout is enabled)
VIOLAWAKE_STRIPE_SECRET_KEY=
VIOLAWAKE_STRIPE_WEBHOOK_SECRET=
VIOLAWAKE_STRIPE_PRICE_DEVELOPER=
VIOLAWAKE_STRIPE_PRICE_BUSINESS=
VIOLAWAKE_SENTRY_DSN=

# Base URL of the console frontend (used for Stripe checkout redirects)
VIOLAWAKE_CONSOLE_BASE_URL=http://localhost:5173
