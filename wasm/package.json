{
  "name": "violawake",
  "version": "0.1.0",
  "description": "ViolaWake wake word detection in the browser via ONNX Runtime Web",
  "type": "module",
  "main": "./dist/violawake.cjs",
  "module": "./dist/violawake.js",
  "types": "./dist/violawake.d.ts",
  "exports": {
    ".": {
      "import": "./dist/violawake.js",
      "require": "./dist/violawake.cjs",
      "types": "./dist/violawake.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c rollup.config.mjs",
    "dev": "rollup -c rollup.config.mjs --watch",
    "demo": "npx serve demo -p 5000",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "onnxruntime-web": "^1.20.1"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-typescript": "^11.1.6",
    "rollup": "^4.18.0",
    "tslib": "^2.6.3",
    "typescript": "^5.4.5"
  },
  "keywords": [
    "wake-word",
    "keyword-spotting",
    "wasm",
    "onnx",
    "browser",
    "voice",
    "ai"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/GeeIHadAGoodTime/ViolaWake"
  }
}
